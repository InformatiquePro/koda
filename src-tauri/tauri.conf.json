{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "koda",
  "version": "0.6.1",
  "identifier": "fr.charles-elie.koda",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "koda",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "args": [
        {
          "name": "dev",
          "short": "d",
          "description": "Active le mode développement avec logs complets",
          "takesValue": false
        }
      ]
    }
  }
}
