{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "koda",
  "version": "0.7.0",
  "identifier": "com.custom-build.koda",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "label": "main",
        "title": "koda",
        "width": 800,
        "height": 600
      },
      {
        "label": "command-palette",
        "url": "command-palette.html",
        "visible": false,
        "width": 680,
        "height": 420,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "args": [
        {
          "name": "dev",
          "short": "d",
          "description": "Active le mode développement avec logs complets",
          "takesValue": false
        }
      ]
    },
    "process": {}
  }
}
